local function GenWithStarter(minV, maxV, starter, digits)
    digits = digits or 18
    if not starter or starter == "" then
        local val = minV + math.random() * (maxV - minV)
        return tonumber(string.format("%." .. digits .. "f", val))
    end
    local tries = 0
    while tries < 80000 do
        local val = minV + math.random() * (maxV - minV)
        local s = string.format("%." .. digits .. "f", val)
        if s:sub(1, #starter) == starter then
            return tonumber(s)
        end
        tries = tries + 1
    end
    return minV + math.random() * (maxV - minV)
end

