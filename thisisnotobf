local function V3GenNum(digits, minV, maxV, starter, length)
    local function gen()
        return string.format("%." .. digits .. "f", minV + math.random() * (maxV - minV))
    end
    if starter and starter ~= "" then
        local attempt = gen()
        local tries = 0
        while attempt:sub(1, #starter) ~= starter do
            attempt = gen()
            tries = tries + 1
            if tries > 10000 then break end
        end
        return attempt:sub(1, length)
    end
    return gen():sub(1, length)
end

local function V3GenSection(label, minV, maxV, digits, count, starter, length)
    local lines = {"[ " .. label .. " ]"}
    for i = 1, count do
        table.insert(lines, "  " .. i .. ". " .. V3GenNum(digits, minV, maxV, starter, length))
    end
    return lines
end

