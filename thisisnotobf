local function ApplyPingPred()
    if not PState.AutoPing then return end
    local gp = GP().Psalms
    local r = gp[PState.Mode] or gp["HvH"]

    PState.HPred    = GenWithStarter(r.hMin,    r.hMax,    PStarters.H    ~= "" and PStarters.H    or nil, 18)
    PState.VPred    = GenWithStarter(r.vMin,    r.vMax,    PStarters.V    ~= "" and PStarters.V    or nil, 18)
    PState.CamHPred = GenWithStarter(r.hMin,    r.hMax,    PStarters.CamH ~= "" and PStarters.CamH or nil, 18)
    PState.CamVPred = GenWithStarter(r.vMin,    r.vMax,    PStarters.CamV ~= "" and PStarters.CamV or nil, 18)

    if PStarters.Jump ~= "" then
        local jStr = PStarters.Jump
        local tries = 0
        while tries < 80000 do
            local val = r.jumpMin + math.random() * (r.jumpMax - r.jumpMin)
            local s = string.format("%.4f", val)
            if s:sub(1, #jStr) == jStr then
                PState.JumpOffset = tonumber(s)
                break
            end
            tries = tries + 1
        end
    end

    if PStarters.Fall ~= "" then
        local fStr = PStarters.Fall
        local tries = 0
        while tries < 80000 do
            local val = r.fallMin + math.random() * (r.fallMax - r.fallMin)
            local s = string.format("%.4f", val)
            if s:sub(1, #fStr) == fStr then
                PState.FallOffset = tonumber(s)
                break
            end
            tries = tries + 1
        end
    end
end

