            "\nMethod    : " .. VState.AimlockMethod ..
            "\nLock Part : " .. VState.LockPart ..
            "\n\nCopied!"
        )
    end

    setclipboard(VState.Output)
    Library:Notify("vertical.hit CFG copied! (" .. SelectedGame .. ")", 4)
end)

