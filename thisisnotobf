    if ext == "Celex"   then return BuildCelex(ping, cfgType, predType, m)
    elseif ext == "Ethic"   then return BuildJsonExt(ping, cfgType, 360,  6,  0, 2, true,  m)
    elseif ext == "Horizon" then return BuildJsonExt(ping, cfgType, 360,  69, 0, 0, false, m)
    elseif ext == "Silence" then return BuildJsonExt(ping, cfgType, 360,  6,  0, 2, true,  m)
    elseif ext == "Xuaa"    then return BuildJsonExt(ping, cfgType, 1000, 6,  1, 2, false, m)
    elseif ext == "Phobia"  then return BuildPhobia(ping, cfgType, m)
    elseif ext == "Mono"    then return BuildMono(ping, cfgType, m)
    elseif ext == "Severe"  then return BuildSevere(ping, cfgType, m)
    end
    return "Unknown."
end

