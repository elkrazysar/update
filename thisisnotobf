local HudBtn = Library:CreateMobileButton({
    Text = "GEN",
    Size = UDim2.fromOffset(52, 52),
    Pos  = UDim2.new(0.85, 0, 0.5, 0),
})

do
    local dragStart, startPos, dragging = nil, nil, false

    HudBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch then
            dragStart = inp.Position
            startPos  = HudBtn.Position
            dragging  = false
        end
    end)

    HudBtn.InputChanged:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch and dragStart then
            local d = inp.Position - dragStart
            if math.abs(d.X) > 8 or math.abs(d.Y) > 8 then
                dragging = true
                HudBtn.Position = UDim2.new(0, startPos.X.Offset + d.X, 0, startPos.Y.Offset + d.Y)
            end
        end
    end)

    HudBtn.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch then
            if not dragging then
                if PState.AutoPing then ApplyPingPred() end
                setclipboard(BuildPsalmsCfg(PState))
                Library:Notify("Psalms CFG copied! (" .. SelectedGame .. ")", 3)
            end
            dragStart = nil
            dragging  = false
        end
    end)
end

