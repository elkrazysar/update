local function BuildCelex(ping, cfgType, predType, mult)
    local cfg = TYPE_CONFIGS[cfgType]
    local dx, dy = DivFormula(ping, mult)
    local m = LookupPing(ping, mult)
    local pt = ""
    if predType == "Multiplication" then pt = 'pred_type = "1";\n' end
    return 'aimbot-enabled = "1";\naimbot-smoothing = "' .. cfg.smoothing .. '";\naimbot-sensitivity = "' .. cfg.sensitivity .. '";\naimbot-bind = "5";\naimbot-part = "2";\nstreamproof = "0";\nv-sync = "1";\nprediction = "1";\nstickyaim = "1";\nteamcheck = "0";\nknocheck = "0";\naimbot-fov = "1000";\npred_x = "' .. string.format("%.15f", dx) .. '";\npred_y = "' .. string.format("%.15f", dy) .. '";\npred = "' .. string.format("%.15f", m) .. '";\nx_offset = "0";\ny_offset = "0";\naimbot_type = "1";\nno_jump = "1";\n' .. pt
end

