local function LookupPing(ping, mult)
    mult = mult or 1.0
    local base = PING_TABLE[490]
    for i, k in ipairs(PING_KEYS) do
        local nxt = PING_KEYS[i+1] or 500
        if ping > k and ping <= nxt then
            base = PING_TABLE[k]
            break
        end
    end
    return base * mult
end

local function DivFormula(ping, mult)
    mult = mult or 1.0
    return (7.015 + (-0.01276 * ping)) * mult,
           (7.1415 + (-0.014512 * ping)) * mult
end

