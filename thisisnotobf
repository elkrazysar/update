        local gp = GP().Psalms
        local r = gp[PState.Mode] or gp["HvH"]
        local base = LookupPing(VState.Ping, GP().PsalmsMult)
        local predVal = GenWithStarter(
            math.max(0.00005, base * 0.4),
            base * 0.6,
            VState.PredStarter ~= "" and VState.PredStarter or nil,
            18
        )
        VState.AimlockPrediction = string.format("%.18f", predVal)
    else
        local base = LookupPing(VState.Ping, GP().PsalmsMult)
        VState.AimlockPrediction = string.format("%.18f", base * 0.5)
    end

    VState.Output = BuildVerticalCfg()

    if VOutLabel then
