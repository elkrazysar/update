local function BuildVerticalCfg()
    local pred = VState.AimlockPrediction

    local objects = {
        {idx="AimlockEnabled",   type="Toggle",   value=VState.AimlockEnabled},
        {idx="SilentAimEnabled", type="Toggle",   value=VState.SilentAimEnabled},
        {idx="EspEnabled",       type="Toggle",   value=VState.EspEnabled},
        {idx="EspBoxes",         type="Toggle",   value=VState.EspBoxes},
        {idx="EspHealth",        type="Toggle",   value=VState.EspHealth},
        {idx="EspNames",         type="Toggle",   value=VState.EspNames},
        {idx="EspDistance",      type="Toggle",   value=VState.EspDistance},
        {idx="EspTracers",       type="Toggle",   value=VState.EspTracers},
        {idx="Highlight",        type="Toggle",   value=VState.Highlight},
        {idx="FOVEnabled",       type="Toggle",   value=VState.FOVEnabled},
        {idx="CrosshairEnabled", type="Toggle",   value=VState.CrosshairEnabled},
        {idx="HitSoundEnabled",  type="Toggle",   value=VState.HitSoundEnabled},
        {idx="HitNotifyEnabled", type="Toggle",   value=VState.HitNotifyEnabled},
        {idx="SpeedEnabled",     type="Toggle",   value=VState.SpeedEnabled},
        {idx="Noclip",           type="Toggle",   value=VState.NoclipEnabled},
        {idx="AntiVoid",         type="Toggle",   value=VState.AntiVoid},
        {idx="ShowAimlockFOV",   type="Toggle",   value=false},
        {idx="BulletTP",         type="Toggle",   value=false},
        {idx="NoJumpCooldown",   type="Toggle",   value=false},
        {idx="SpinbotEnabled",   type="Toggle",   value=false},
        {idx="AntiSlow",         type="Toggle",   value=false},
        {idx="TargetStrafeEnabled",type="Toggle", value=false},
        {idx="Rainbow",          type="Toggle",   value=false},
        {idx="AimlockMethod",    type="Dropdown", value=VState.AimlockMethod},
        {idx="LockPart",         type="Dropdown", value=VState.LockPart},
        {idx="SilentAimHitParts",type="Dropdown", value=VState.SilentHitPart},
        {idx="CrosshairMode",    type="Dropdown", value=VState.CrosshairMode},
        {idx="BoxMode",          type="Dropdown", value="Normal"},
        {idx="NameType",         type="Dropdown", value="DisplayName"},
        {idx="NotificationSide", type="Dropdown", value="Right"},
        {idx="HitSoundSelect",   type="Dropdown", value="Gamesense"},
        {idx="AimlockFOV",       type="Slider",   value=tostring(VState.AimlockFOV)},
        {idx="AimlockSmoothness",type="Slider",   value=tostring(VState.AimlockSmoothness)},
        {idx="FOVSlider",        type="Slider",   value=tostring(VState.FOVSlider)},
        {idx="SilentAimFOVSlider",type="Slider",  value=tostring(VState.SilentFOV)},
        {idx="SpeedSlider",      type="Slider",   value=tostring(VState.SpeedSlider)},
        {idx="EspMaxDistance",   type="Slider",   value="5000"},
        {idx="LockMaxDistance",  type="Slider",   value="1000"},
        {idx="AimlockPrediction",type="Input",    text=pred},
        {idx="SilentAimOffsetInput",type="Input", text=VState.SilentOffset},
        {idx="MaxDistanceInput", type="Input",    text="250"},
        {idx="AimlockChecks",    type="Dropdown", value={}},
        {idx="TriggerChecks",    type="Dropdown", value={["Wall Check"]=VState.WallCheck,["Alive Check"]=VState.AliveCheck}},
        {idx="BoxColorPicker",       type="ColorPicker",transparency=0,value="ffffff"},
        {idx="HealthHighColorPicker",type="ColorPicker",transparency=0,value="00ff00"},
        {idx="HealthLowColorPicker", type="ColorPicker",transparency=0,value="ff0000"},
        {idx="NameColorPicker",      type="ColorPicker",transparency=0,value="ffffff"},
        {idx="AimlockFOVColor",      type="ColorPicker",transparency=0,value="ffffff"},
        {idx="FOVColorPicker",       type="ColorPicker",transparency=0,value="ffffff"},
        {idx="TracerColorPicker",    type="ColorPicker",transparency=0,value="ffffff"},
        {idx="HighlightColorPicker", type="ColorPicker",transparency=0,value="ffffff"},
        {idx="AimlockKeybind",   type="KeyPicker", key="X",mode="Toggle",modifiers={}},
        {idx="SpeedKeybind",     type="KeyPicker", key="B",mode="Toggle",modifiers={}},
    }

    local parts = {}
    for _, obj in ipairs(objects) do
        local entry = '{"idx":"' .. obj.idx .. '","type":"' .. obj.type .. '"'
        if obj.type == "Toggle" then
            entry = entry .. ',"value":' .. tostring(obj.value)
        elseif obj.type == "Dropdown" then
            if type(obj.value) == "table" then
                local inner = ""
                for k, v in pairs(obj.value) do
                    if inner ~= "" then inner = inner .. "," end
                    inner = inner .. '"' .. k .. '":' .. tostring(v)
                end
                entry = entry .. ',"multi":true,"value":{' .. inner .. '}'
            else
                entry = entry .. ',"multi":false,"value":"' .. tostring(obj.value) .. '"'
            end
        elseif obj.type == "Slider" then
            entry = entry .. ',"value":"' .. obj.value .. '"'
        elseif obj.type == "Input" then
            entry = entry .. ',"text":"' .. obj.text .. '"'
        elseif obj.type == "ColorPicker" then
            entry = entry .. ',"transparency":' .. obj.transparency .. ',"value":"' .. obj.value .. '"'
        elseif obj.type == "KeyPicker" then
            entry = entry .. ',"key":"' .. obj.key .. '","mode":"' .. obj.mode .. '","modifiers":[]'
        end
        entry = entry .. "}"
        table.insert(parts, entry)
    end

    return '{"objects":[' .. table.concat(parts, ",") .. "]}"
end

