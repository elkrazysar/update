local function RunV3()
    V3State.Results = {}
    local gameRanges  = GAME_V3_RANGES[SelectedGame] or GAME_V3_RANGES["Custom"]
    local styleRanges = gameRanges[V3State.Style] or gameRanges["HvH"]
    local digits      = PREC_DIGITS[V3State.Precision] or 15
    local perSect     = math.max(1, math.floor(V3State.Count / 3))
    local starter     = V3State.Starter ~= "" and V3State.Starter or nil

    local longMin,  longMax  = styleRanges.Long[1],  styleRanges.Long[2]
    local medMin,   medMax   = styleRanges.Med[1],   styleRanges.Med[2]
    local closeMin, closeMax = styleRanges.Close[1], styleRanges.Close[2]

    local sects = {
        V3GenSection("Long Range",  longMin,  longMax,  digits, perSect, starter, V3State.Length),
        V3GenSection("Med Range",   medMin,   medMax,   digits, perSect, starter, V3State.Length),
        V3GenSection("Close Range", closeMin, closeMax, digits, perSect, starter, V3State.Length),
    }

    table.insert(V3State.Results, "=== V3 SETS ===")
    table.insert(V3State.Results, "Game      : " .. SelectedGame)
    table.insert(V3State.Results, "Style     : " .. V3State.Style)
    table.insert(V3State.Results, "Precision : " .. V3State.Precision)
    table.insert(V3State.Results, "Velocity  : " .. V3State.Velocity)
    table.insert(V3State.Results, "Extra     : " .. V3State.Extra)
    table.insert(V3State.Results, string.format("Long Rng  : %.4f to %.4f", longMin, longMax))
    table.insert(V3State.Results, string.format("Med Rng   : %.4f to %.4f", medMin, medMax))
    table.insert(V3State.Results, string.format("Close Rng : %.4f to %.4f", closeMin, closeMax))
    table.insert(V3State.Results, "================")

    for _, sect in ipairs(sects) do
        for _, line in ipairs(sect) do
            table.insert(V3State.Results, line)
        end
        table.insert(V3State.Results, "")
    end

    table.insert(V3State.Results, "================")
    table.insert(V3State.Results, "Total : " .. (perSect * 3) .. " sets")
    table.insert(V3State.Results, "Game  : " .. SelectedGame)
end

